# Resend (https://resend.com) — required for enquiry form emails
RESEND_API_KEY=

# Must use a domain you’ve verified in Resend (DNS for mail.millerfirstaid.com.au)
# Default below matches the Miller First Aid sending domain.
RESEND_FROM_EMAIL=Miller First Aid <enquiries@mail.millerfirstaid.com.au>

# Where enquiries are delivered (inbox)
ENQUIRY_TO_EMAIL=info@millerfirstaid.com.au

# Google Tag Manager container (public client-side variable)
NEXT_PUBLIC_GTM_ID=GTM-WH87DTFZ
